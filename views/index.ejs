<%
  // High-end utilities for the premium UI
  norm = (value) => (value || "").normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/đ/g, "d").replace(/Đ/g, "D").toLowerCase().trim();
  toInt = (value) => { const m = String(value || "").match(/\d+/); return m ? Number(m[0]) : 9999; };
  accentFromText = (text) => {
    const source = String(text || "").trim() || "EAUT";
    let hash = 0;
    for (let i = 0; i < source.length; i += 1) hash = (hash * 31 + source.charCodeAt(i)) >>> 0;
    return `hsl(${hash % 360} 78% 72%)`;
  };
  dayLabel = (dayIndex) => (dayIndex === 8 ? "Chủ nhật" : `Thứ ${dayIndex}`);
  shiftFromPeriodStart = (p, s) => {
    const start = toInt(p);
    if (start >= 1 && start <= 3) return { shift: 1, range: "7:00 - 9:30" };
    if (start >= 4 && start <= 6) return { shift: 2, range: "9:40 - 12:10" };
    if (start >= 7 && start <= 9) return { shift: 3, range: "13:00 - 15:30" };
    if (start >= 10 && start <= 12) return { shift: 4, range: "15:40 - 18:10" };
    return { shift: 5, range: "18:30 - 21:00" };
  };
%>
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lịch học EAUT - Giao diện Premium</title>
    <link rel="stylesheet" href="/styles.css" />
    <style>
      #progressBar { position: fixed; top: 0; left: 0; height: 3px; background: var(--primary); z-index: 9999; width: 0%; transition: width 0.3s ease; display: none; }
      .loading-overlay { position: fixed; inset: 0; background: rgba(8, 10, 22, 0.98); backdrop-filter: blur(15px); display: flex; align-items: center; justify-content: center; z-index: 10000; }
      .spinner { width: 60px; height: 60px; border: 5px solid rgba(124, 139, 255, 0.1); border-top-color: var(--primary); border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 1.5rem; }
      @keyframes spin { to { transform: rotate(360deg); } }
      .is-hidden { display: none !important; }
    </style>
  </head>
  <body class="dashboard-layout">
    <div id="progressBar"></div>
    <div class="app-shell">
      <div class="app-layout">
        <aside class="sidebar">
          <a class="sidebar-brand" href="/">
            <div class="brand-badge">📚</div>
            <div>
              <div class="sidebar-title">EAUT Schedule</div>
              <div class="sidebar-subtitle">Pastel · Gọn · Dễ nhìn</div>
            </div>
          </a>
          <nav class="sidebar-nav">
            <a class="nav-item <%= activeTab === 'week' ? 'is-active' : '' %>" href="/schedule/week">
              <span class="nav-icon">🗓️</span>
              <span class="nav-label">Lịch học tuần</span>
              <span class="nav-hint">WEEKLY</span>
            </a>
            <a class="nav-item <%= activeTab === 'term' ? 'is-active' : '' %>" href="/schedule/term">
              <span class="nav-icon">📅</span>
              <span class="nav-label">Lịch học kỳ</span>
              <span class="nav-hint">TERM</span>
            </a>
            <a class="nav-item <%= activeTab === 'exam' ? 'is-active' : '' %>" href="/schedule/exam">
              <span class="nav-icon">🧸</span>
              <span class="nav-label">Lịch thi</span>
              <span class="nav-hint">EXAMS</span>
            </a>
          </nav>
          <div class="sidebar-footer">
            <div class="cute-tip">Mẹo nhỏ: bạn có thể lọc nhanh theo <strong>môn/phòng/giảng viên</strong> và chuyển chế độ xem bảng khi cần.</div>
          </div>
        </aside>

        <div class="app-main">
          <header class="site-header">
            <div class="header-inner">
              <div class="header-left">
                <button class="icon-btn" data-sidebar-toggle>☰</button>
                <div style="min-width:0">
                  <div class="header-title">Lịch học EAUT</div>
                  <div class="header-subtitle">Anh Thùy IT - 15C2</div>
                </div>
              </div>
              <div class="header-actions">
                <button class="icon-btn" data-theme-toggle>🌙</button>
                <% if (studentName) { %>
                  <div class="user-pill"><%= studentName %></div>
                  <a class="btn btn-ghost btn-sm" href="/logout">Đăng xuất</a>
                <% } else { %>
                  <a class="btn btn-primary btn-sm" href="/">Đăng nhập</a>
                <% } %>
              </div>
            </div>
          </header>

          <main class="page-content" id="workspace">
            <% if (!studentName) { %>
              <div class="workspace-layout">
                <div class="auth-section">
                  <aside class="panel auth-panel">
                    <h2>Đăng nhập</h2>
                    <p class="muted">Đồng bộ lịch học tức thì từ hệ thống sinh viên.</p>
                    <form action="/schedule" method="post" id="loginForm">
                      <div class="field">
                        <label>Mã sinh viên</label>
                        <input name="username" type="text" required placeholder="2400xxxx" value="<%= (typeof formData !== 'undefined' && formData.username) || '' %>" />
                      </div>
                      <div class="field">
                        <label>Mật khẩu</label>
                        <input name="password" type="password" required placeholder="Mật khẩu" />
                      </div>
                      <button type="submit" class="btn btn-primary">Đồng bộ lịch học</button>
                    </form>
                    <% if (typeof error !== 'undefined' && error) { %>
                      <div class="alert alert-error" style="margin-top: 1rem;"><%= error %></div>
                    <% } %>
                  </aside>
                  <aside class="panel donate-panel">
                    <h3>Duy trì Web ☕</h3>
                    <div class="donate-card">
                      <div class="donate-row"><span>MB Bank:</span> <strong>23920000000006</strong></div>
                      <div class="donate-row"><span>Chủ TK:</span> <strong>PHUNG VINH THUY</strong></div>
                    </div>
                  </aside>
                </div>
                <div class="panel empty-state" style="margin-top: 2rem; text-align: center; padding: 4rem 2rem;">
                   <h2 style="font-size: 2rem; font-weight: 900; margin-bottom: 1rem;">Chưa có dữ liệu lịch học</h2>
                   <p class="muted">Đăng nhập để hiển thị lịch học theo giao diện Premium mới.</p>
                </div>
            <% } else { %>
              <% if (activeTab === 'week') { %>
                <section class="panel schedule-panel">
                   <div class="panel-header">
                     <h2>Lịch học tuần của bạn</h2>
                     <p class="muted">Cập nhật: <%= result.fetchedAt %></p>
                   </div>
                   <div class="schedule-toolbar">
                      <div class="toolbar-group">
                        <label>Tuần học</label>
                        <select onchange="window.location.href='/schedule/week?week='+this.value">
                          <% (result.weekOptions || []).forEach(w => { %>
                            <option value="<%= w.value %>" <%= w.value === result.selectedWeekValue ? 'selected' : '' %>><%= w.label %></option>
                          <% }) %>
                        </select>
                      </div>
                      <div class="toolbar-group" style="flex:1;">
                        <label>Lọc nhanh</label>
                        <input id="subjectFilter" type="text" placeholder="Môn / Phòng / GV..." />
                      </div>
                   </div>
                   <div class="week-board">
                     <table class="week-grid">
                        <thead><tr><th>CA</th><% [2,3,4,5,6,7,8].forEach(d => { %><th><%= d===8 ? 'CN' : 'Thứ '+d %><br><small style="font-weight:400; opacity:0.7;"><%= (result.days && result.days[d-2] && result.days[d-2].date) || "" %></small></th><% }) %></tr></thead>
                        <tbody>
                          <% [1,2,3,4,5].forEach(s => { %>
                            <tr>
                              <th class="week-grid__shift">Ca <%= s %><br><small><%= shiftFromPeriodStart(s*3-2).range %></small></th>
                              <% [2,3,4,5,6,7,8].forEach(d => { %>
                                <td class="week-grid__cell">
                                  <% (result.schedule || []).filter(item => item.dayIndex === d && shiftFromPeriodStart(item.periodStart).shift === s).forEach(course => { %>
                                    <div class="session-item" style="border-left: 4px solid <%= accentFromText(course.subjectName) %>" data-search-content="<%= course.subjectName %> <%= course.room %> <%= course.teacherName %>">
                                      <div class="session-name"><%= course.subjectName %></div>
                                      <div class="session-meta">📍 <%= course.room %></div>
                                      <div class="session-meta">👤 <%= course.teacherName %></div>
                                      <div class="session-badge">Tiết <%= course.periodStart %>-<%= course.periodEnd %></div>
                                    </div>
                                  <% }) %>
                                </td>
                              <% }) %>
                            </tr>
                          <% }) %>
                        </tbody>
                     </table>
                   </div>
                </section>
              <% } else if (activeTab === 'term') { %>
                <section class="panel term-panel">
                  <div class="panel-header"><h2>Lịch học kỳ</h2></div>
                  <div class="term-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
                    <% (result.courses || []).forEach(course => { %>
                      <div class="term-card panel" style="padding: 1.5rem; border-top: 5px solid <%= accentFromText(course.subjectName) %>">
                        <div class="card-header" style="display:flex; justify-content:space-between; align-items:flex-start;">
                          <span class="badge" style="background:<%= accentFromText(course.subjectName) %>; color: #000; font-weight:800; font-size:0.7rem;"><%= course.subjectCode.substring(0,2).toUpperCase() %></span>
                          <span class="muted small"><%= course.credits %> tín</span>
                        </div>
                        <h3 style="margin: 0.75rem 0; font-size: 1.1rem; line-height:1.4;"><%= course.subjectName %></h3>
                        <div class="card-body muted small" style="display:grid; gap:0.5rem;">
                          <div>👤 GV: <%= course.teacherName %></div>
                          <div>📍 Phòng: <%= course.room %></div>
                          <div style="margin-top:1rem; border-top: 1px solid var(--line); padding-top:1rem;">
                            <div style="font-weight:800; margin-bottom:0.5rem;">THỜI GIAN HỌC</div>
                            <div>📅 <%= course.timeRange %></div>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </section>
              <% } else if (activeTab === 'exam') { %>
                <section class="panel exam-panel">
                  <div class="panel-header"><h2>Lịch thi của bạn</h2></div>
                  <div class="exam-list" style="display: grid; gap: 1rem;">
                    <% (result.exams || []).forEach(exam => { %>
                      <div class="exam-item panel" style="display: flex; gap: 1.5rem; align-items: center; padding: 1.25rem;">
                        <div class="exam-date" style="text-align: center; min-width: 80px; padding-right: 1.5rem; border-right: 1px solid var(--line);">
                          <div style="font-size: 1.5rem; font-weight: 900;"><%= exam.date.split('/')[0] %></div>
                          <div class="muted small">THÁNG <%= exam.date.split('/')[1] %></div>
                        </div>
                        <div style="flex: 1;">
                          <h4 style="margin: 0 0 0.25rem 0;"><%= exam.subjectName %></h4>
                          <div class="muted small">📍 <%= exam.room %> | ⏰ <%= exam.time %> | 🆔 SBD: <%= exam.sbd %></div>
                        </div>
                        <div class="exam-status">
                          <span class="badge"><%= exam.format || "Thi viết" %></span>
                        </div>
                      </div>
                    <% }) %>
                    <% if (!(result.exams && result.exams.length)) { %>
                      <div class="muted" style="text-align: center; padding: 2rem;">Chưa có lịch thi được công bố.</div>
                    <% } %>
                  </div>
                </section>
              <% } %>
            <% } %>
          </main>
        </div>
      </div>
    </div>
    <div id="loadingOverlay" class="loading-overlay is-hidden">
      <div class="loading-content"><div class="spinner"></div><h2>Đang đồng bộ dữ liệu...</h2></div>
    </div>
    <script src="/app.js"></script>
    <script>
      const pb = document.getElementById('progressBar');
      document.addEventListener('click', e => {
        const a = e.target.closest('.nav-item');
        if (a && a.getAttribute('href').startsWith('/')) {
          e.preventDefault();
          const href = a.getAttribute('href');
          pb.style.display='block'; pb.style.width='80%';
          fetch(href).then(r=>r.text()).then(html=>{
            const doc = new DOMParser().parseFromString(html, 'text/html');
            document.querySelector('.page-content').innerHTML = doc.querySelector('.page-content').innerHTML;
            window.history.pushState({}, '', href);
            document.querySelectorAll('.nav-item').forEach(i=>i.classList.toggle('is-active', i.getAttribute('href')===href));
          }).finally(()=>{ pb.style.width='100%'; setTimeout(()=>pb.style.display='none', 200); });
        }
      });
      const lf = document.getElementById('loginForm');
      if (lf) lf.addEventListener('submit', () => document.getElementById('loadingOverlay').classList.remove('is-hidden'));
    </script>
  </body>
</html>
